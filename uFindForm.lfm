object FindForm: TFindForm
  Left = 0
  Top = 0
  Caption = 'Find / Replace'
  BorderStyle = bsDialog
  BorderIcons = [biSystemMenu]
  ClientHeight = 190
  ClientWidth = 470
  Position = poOwnerFormCenter
  object FindLabel: TLabel
    Left = 8
    Top = 16
    Caption = 'Find:'
  end
  object ReplaceLabel: TLabel
    Left = 8
    Top = 50
    Caption = 'Replace:'
  end
  object StatusLabel: TLabel
    Left = 8
    Top = 160
    Caption = ''
    Font.Color = clRed
    Font.Style = []
    ParentFont = False
  end
  object FindEdit: TEdit
    Left = 76
    Top = 11
    Width = 288
    TabOrder = 0
    OnKeyDown = EditKeyDown
  end
  object ReplaceEdit: TEdit
    Left = 76
    Top = 43
    Width = 288
    TabOrder = 1
    OnKeyDown = EditKeyDown
  end
  object CaseCB: TCheckBox
    Left = 8
    Top = 80
    Caption = 'Match &case'
    TabOrder = 2
  end
  object WordCB: TCheckBox
    Left = 128
    Top = 80
    Caption = '&Whole word'
    TabOrder = 3
  end
  object FindNextBtn: TButton
    Left = 376
    Top = 8
    Width = 86
    Height = 28
    Caption = 'Find &Next'
    Default = True
    TabOrder = 4
    OnClick = FindNextBtnClick
  end
  object ReplaceBtn: TButton
    Left = 376
    Top = 40
    Width = 86
    Height = 28
    Caption = '&Replace'
    TabOrder = 5
    OnClick = ReplaceBtnClick
  end
  object ReplaceAllBtn: TButton
    Left = 376
    Top = 72
    Width = 86
    Height = 28
    Caption = 'Replace &All'
    TabOrder = 6
    OnClick = ReplaceAllBtnClick
  end
  object CloseBtn: TButton
    Left = 376
    Top = 110
    Width = 86
    Height = 28
    Caption = '&Close'
    Cancel = True
    TabOrder = 7
    OnClick = CloseBtnClick
  end
end
